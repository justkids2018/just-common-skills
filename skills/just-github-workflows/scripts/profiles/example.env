# 复制此文件为 profiles/<provider>.env 并填写真实值
DEPLOY_PROVIDER="my_provider"
DEPLOY_SSH_USER="ubuntu"
DEPLOY_SERVER_IP="1.2.3.4"
DEPLOY_REMOTE_DIR="/opt/myapp"

DEPLOY_PRIMARY_DOMAIN="app.example.com"
DEPLOY_MOBILE_DOMAIN="app.example.com"
DEPLOY_ADMIN_DOMAIN="admin.example.com"
DEPLOY_API_DOMAIN="app.example.com"
DEPLOY_API_PATH_PREFIX="/api"

DEPLOY_STACK_NAME="myapp_stack"
DEPLOY_ADMIN_HOST_PORT="18080"
DEPLOY_BACKEND_HOST_PORT="18001"
DEPLOY_POSTGRES_HOST_PORT="15432"

DEPLOY_DATABASE_NAME="myapp_db"
DEPLOY_DATABASE_USER="postgres"
DEPLOY_DATABASE_PASSWORD="change-me-db"
DEPLOY_JWT_SECRET="change-me-jwt"
DEPLOY_LOG_LEVEL="info"

DEPLOY_ADMIN_API_BASE_URL="https://app.example.com/api"

# Docker 镜像（需与 docker-release.yml 里的 IMAGE_BACKEND / IMAGE_ADMIN 一致）
DEPLOY_BACKEND_IMAGE="ghcr.io/<org>/<project>-backend:latest"
DEPLOY_ADMIN_IMAGE="ghcr.io/<org>/<project>-admin:latest"
